{
	"format_version": "1.21.60",
	"minecraft:block": {
		"description": {
			"identifier": "qcs_portfolio:diamond_flower",
			"menu_category": {
				"category": "none",
				"is_hidden_in_commands": true
			},
			"states": {
				"qcs_portfolio:growth": {
					"values": {"min": 0, "max": 7}
				}
			}
		},
		"components": {
			"qcs_portfolio:crop": {
				"growth_state": "qcs_portfolio:growth",
				"max_growth": 7,
				"harvest_tool": "minecraft:shears",
				"harvest_sound": "mob.sheep.shear"
			},
			"qcs_portfolio:ambient_particles": {
				"particle_identifier": "qcs_portfolio:sparkles"
			},
			"minecraft:tick": {
				"interval_range": [20, 140],
				"looping": true
			},
			"minecraft:flammable": true,
			"minecraft:collision_box": false,
			"minecraft:geometry": "geometry.qcs_portfolio.flower",
			"minecraft:light_dampening": 0,
			"minecraft:placement_filter": {
				"conditions": [
					{
						"allowed_faces": ["up"],
						"block_filter": [
							"minecraft:grass_block",
							"minecraft:dirt"
						]
					}
				]
			}
		},
		"permutations": [
			{
				"condition": "q.block_state('qcs_portfolio:growth') >= 0",
				"components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "texture.qcs_portfolio.diamond_flower_stage00",
							"render_method": "alpha_test",
							"ambient_occlusion": false,
							"face_dimming": false
						}
					},
					"minecraft:selection_box": {
						"origin": [-5, 0, -5],
						"size": [10, 6 ,10]
					},
					"minecraft:loot": "loot_tables/qcs/portfolio/blocks/diamond_flower_young.loot.json"
				}
			},
			{
				"condition": "q.block_state('qcs_portfolio:growth') >= 4",
				"components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "texture.qcs_portfolio.diamond_flower_stage01",
							"render_method": "alpha_test",
							"ambient_occlusion": false,
							"face_dimming": false
						}
					},
					"minecraft:selection_box": {
                        "origin": [-5, 0, -5],
						"size": [10, 10 ,10]
                    },
					"minecraft:loot": "loot_tables/qcs/portfolio/blocks/diamond_flower_young.loot.json"
				}
			},
			{
				"condition": "q.block_state('qcs_portfolio:growth') >= 7",
				"components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "texture.qcs_portfolio.diamond_flower_stage02",
							"render_method": "alpha_test",
							"ambient_occlusion": false,
							"face_dimming": false
						}
					},
					"minecraft:selection_box": {
						"origin": [-5, 0, -5],
						"size": [10, 16 ,10]
					},
					"minecraft:loot": "loot_tables/qcs/portfolio/blocks/diamond_flower_mature.loot.json"
				}
			}
		]
	}
}